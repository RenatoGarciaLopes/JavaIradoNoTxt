classDiagram
    class ValidateLogin {
        -Map~String, String~ USERS
        -MIN_PASSWORD_LENGTH : int
        -MAX_PASSWORD_LENGTH : int
        -String email
        -String password
        +ValidateLogin(String email, String password)
        +boolean isValid()
        -boolean hasValidEmail(String email)
        -boolean hasValidPassword(String password)
    }

    class ValidateEmail {
        +validate(String email) : boolean
    }

    ValidateLogin ..> ValidateEmail : uses
